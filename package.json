{
  "name": "game2grow-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm --workspace @game2grow/web run dev",
    "build": "npm run build:web",
    "build:web": "npm --workspace @game2grow/web run build",
    "predeploy": "npm run build:web",
    "deploy": "gh-pages --no-history -d apps/web/dist -r git@github.com:prosanjayselva/Anjen-Fernando.git"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0"
  }
}
