{
  "name": "game2grow-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm --workspace @game2grow/web run dev",
    "dev:api": "npm --workspace @game2grow/api run dev",
    "build": "npm run build -ws"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
